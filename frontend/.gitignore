# filename: .gitignore

# ======================
# Secrets / ENV (NEVER COMMIT)
# ======================
.env
.env.*
*.env
backend/.env*
frontend/.env*
secrets/

# ======================
# OS / Logs
# ======================
*.log
.DS_Store
Thumbs.db

# ======================
# Python / Django
# ======================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.sqlite3
*.db
.venv/
venv/
.envrc

# Django runtime data (PROD = volumes)
media/
staticfiles/

# ======================
# Node / Next.js
# ======================
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ======================
# IDE / Editors
# ======================
.vscode/
.idea/

# ======================
# Docker
# ======================
**/.dockerignore
